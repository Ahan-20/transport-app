# Copy to .env (for local) and fill in. On Railway, set these in the service
# "Variables" tab instead — do not commit a real .env file.

# Cookie encryption secret. Must be at least 32 chars of random text.
# Generate one with: openssl rand -hex 32
SESSION_PASSWORD=change-me-at-least-32-characters-of-random-text

# Absolute path to the SQLite file. On Railway this lives on the mounted
# volume; locally leave blank to use ./data/transport.db.
# DATABASE_PATH=/app/data/transport.db

# First-boot seed. If the users table is empty AND INITIAL_ADMIN_PASSWORD is
# set, the app creates these accounts automatically. After the first boot
# succeeds you can delete these vars — they're no-ops once users exist.
# INITIAL_ADMIN_USERNAME=admin
# INITIAL_ADMIN_PASSWORD=pick-a-strong-password
# INITIAL_ADMIN_NAME=Administrator
# INITIAL_STAFF_USERNAME=transport
# INITIAL_STAFF_PASSWORD=another-strong-password
# INITIAL_STAFF_NAME=Transport Head

# Password reset. If you forget a password, set this env var, redeploy, then
# DELETE the env var and redeploy again. The hash is rewritten on every boot
# the env var is set, so leaving it in place would keep overwriting any
# password change made through a future UI.
# RESET_ADMIN_PASSWORD=new-password-here
# RESET_STAFF_PASSWORD=new-password-here

# EMERGENCY override. If RESET_*_PASSWORD doesn't work for any reason
# (bcrypt mismatch, encoding issue, etc.), set this to log in directly:
# the value below is compared character-for-character to what the user
# types in the login form, bypassing bcrypt and the DB hash entirely.
# DELETE THIS ENV VAR AS SOON AS YOU RECOVER ACCESS — leaving it set
# means anyone who learns the value can log in as admin.
# EMERGENCY_ADMIN_PASSWORD=temporary-recovery-password
# EMERGENCY_ADMIN_USERNAME=admin   # defaults to "admin"
